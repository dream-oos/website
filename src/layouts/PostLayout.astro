---
import BaseLayout from './BaseLayout.astro';
interface Props { title: string; date: Date; description?: string; tags?: string[]; cover?: string; coverAlt?: string; }
const { title, date, description, tags = [], cover, coverAlt } = Astro.props;
const fmt = date.toISOString().slice(0, 10);
---
<BaseLayout title={title} description={description} image={cover}>
  <article class="container prose">
    <h1>{title}</h1>
    <p class="muted post-meta">
      <time datetime={date.toISOString()}>{fmt}</time>
      {tags.length > 0 && <span> / {tags.join(' / ')}</span>}
    </p>
    {cover && (
      <img class="post-cover" src={cover} alt={coverAlt ?? title} loading="eager" decoding="async" />
    )}
    <slot />
  </article>
</BaseLayout>
<style>
  .post-meta { font-size: .85rem; margin-top: -.35rem; margin-bottom: 1.5rem; font-variant-numeric: tabular-nums; }
  article { padding-top: clamp(2.5rem, 7vw, 4.5rem); }
  .post-cover {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: var(--radius);
    margin-bottom: clamp(1.5rem, 4vw, 2.25rem);
    background: var(--color-surface);
  }
</style>

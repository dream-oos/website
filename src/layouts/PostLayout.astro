---
import BaseLayout from './BaseLayout.astro';
import Waline from '../components/Waline.astro';
import FloatingToolbar from '../components/FloatingToolbar.astro';
import { site } from '../config/site';
interface Props { title: string; date: Date; description?: string; tags?: string[]; }
const { title, date, description, tags = [] } = Astro.props;
const fmt = date.toISOString().slice(0, 10);
---
<BaseLayout title={title} description={description}>
  <article class="container container--reading post-page">
    <header class="post-hero" data-reveal>
      <p class="eyebrow">文章</p>
      <h1>{title}</h1>
      <p class="muted post-meta">
        <time datetime={date.toISOString()}>{fmt}</time>
        {tags.length > 0 && <span> / {tags.join(' / ')}</span>}
      </p>
    </header>
    <div class="post-body surface-shell">
      <div class="prose surface-core">
        <slot />
      </div>
    </div>
    {site.walineServerURL && <Waline serverURL={site.walineServerURL} />}
  </article>
  <FloatingToolbar />
</BaseLayout>
<script>
  import { enhanceCodeBlocks } from '../scripts/code-block';
  enhanceCodeBlocks();
</script>
<style>
  .post-page { padding-block: clamp(3rem, 8vw, 6rem); }
  .post-hero { max-width: 58rem; }
  .post-hero h1 { font-size: clamp(2.45rem, 6vw, 4.6rem); }
  .post-meta {
    margin-top: 1.15rem;
    font-size: .82rem;
    font-weight: 720;
    letter-spacing: .08em;
    text-transform: uppercase;
    font-variant-numeric: tabular-nums;
  }
  .post-body { margin-top: clamp(2rem, 5vw, 3rem); }
  .post-body .prose {
    padding: clamp(1.3rem, 4vw, 2.35rem);
  }
</style>

---
import '../styles/global.css';
import ParticleBackground from '../components/ParticleBackground.tsx';
import MouseGlow from '../components/MouseGlow.tsx';
import BackToTop from '../components/BackToTop.tsx';
import ThemeToggle from '../components/ThemeToggle.tsx';
import MobileNav from '../components/MobileNav.tsx';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = 'Dreamer', 
  description = '一个热爱代码与梦想的开发者的个人空间' 
} = Astro.props;

const currentPath = Astro.url.pathname;

const navLinks = [
  { label: '首页', href: '/' },
  { label: '博客', href: '/blog' },
  { label: '项目', href: '/projects' },
  { label: '友链', href: '/friends' },
  { label: '关于', href: '/about' },
];

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Noto+Sans+SC:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{title}</title>

    <script is:inline>
      (function() {
        const stored = localStorage.getItem('theme');
        if (stored === 'light') {
          document.documentElement.setAttribute('data-theme', 'light');
        } else if (!stored && window.matchMedia('(prefers-color-scheme: light)').matches) {
          document.documentElement.setAttribute('data-theme', 'light');
        }
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Background layers -->
    <ParticleBackground client:load />
    <MouseGlow client:load />

    <!-- Navigation -->
    <header id="main-nav" class="fixed top-0 left-0 right-0 z-50 glass-nav transition-all duration-500">
      <div class="mx-auto max-w-6xl px-5 sm:px-6 lg:px-8">
        <div class="flex h-16 items-center justify-between">
          <!-- Logo -->
          <a href="/" class="group flex items-center gap-2.5" id="nav-logo">
            <div class="w-8 h-8 rounded-lg overflow-hidden flex items-center justify-center">
              <img src="/favicon.png" alt="Dreamer" class="w-full h-full object-cover" />
            </div>
            <span class="text-base font-bold text-gradient hidden sm:inline">Dreamer</span>
          </a>

          <!-- Desktop Nav -->
          <nav class="hidden md:flex items-center gap-0.5" id="nav-links" aria-label="主导航">
            {navLinks.map(link => (
              <a 
                href={link.href}
                class:list={[
                  "px-3.5 py-1.5 rounded-lg text-[13px] font-medium transition-all duration-200",
                  isActive(link.href)
                    ? "nav-link-active bg-accent/8"
                    : "text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:bg-[var(--bg-card)]"
                ]}
              >
                {link.label}
              </a>
            ))}
          </nav>

          <!-- Actions -->
          <div class="flex items-center gap-1.5">
            <div class="hidden md:block">
              <ThemeToggle client:load />
            </div>
            <div class="md:hidden">
              <MobileNav client:load links={navLinks} currentPath={currentPath} />
            </div>
          </div>
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main class="relative z-10 flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="relative z-10 border-t border-[var(--border-card)] mt-24">
      <div class="mx-auto max-w-6xl px-5 sm:px-6 lg:px-8 py-16">
        <div class="flex flex-col items-center gap-6">
          <!-- Brand -->
          <div class="flex items-center gap-2.5">
            <div class="w-7 h-7 rounded-lg overflow-hidden flex items-center justify-center">
              <img src="/favicon.png" alt="Dreamer" class="w-full h-full object-cover" />
            </div>
            <span class="text-gradient font-bold">Dreamer</span>
          </div>
          
          <!-- Social -->
          <div class="flex items-center gap-3">
            <a href="https://github.com/dreamer-oos" target="_blank" rel="noopener noreferrer" 
               class="w-9 h-9 rounded-xl bg-[var(--bg-card)] border border-[var(--border-card)] flex items-center justify-center text-[var(--text-muted)] hover:text-accent hover:border-accent/20 transition-all duration-300" 
               aria-label="GitHub" id="footer-github">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            </a>
            <a href="mailto:hello@dreamer.dev"
               class="w-9 h-9 rounded-xl bg-[var(--bg-card)] border border-[var(--border-card)] flex items-center justify-center text-[var(--text-muted)] hover:text-accent hover:border-accent/20 transition-all duration-300"
               aria-label="Email" id="footer-email">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
            </a>
            <a href="https://space.bilibili.com/" target="_blank" rel="noopener noreferrer"
               class="w-9 h-9 rounded-xl bg-[var(--bg-card)] border border-[var(--border-card)] flex items-center justify-center text-[var(--text-muted)] hover:text-[#fb7299] hover:border-[#fb7299]/30 transition-all duration-300"
               aria-label="Bilibili" id="footer-bilibili">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.813 4.653h.854c1.51.054 2.769.578 3.773 1.574 1.004.995 1.524 2.249 1.56 3.76v7.36c-.036 1.51-.556 2.769-1.56 3.773s-2.262 1.524-3.773 1.56H5.333c-1.51-.036-2.769-.556-3.773-1.56S.036 18.858 0 17.347v-7.36c.036-1.511.556-2.765 1.56-3.76 1.004-.996 2.262-1.52 3.773-1.574h.774l-1.174-1.12a1.234 1.234 0 0 1 0-1.733 1.234 1.234 0 0 1 1.734 0L8.58 4.653h6.84l1.813-1.7a1.234 1.234 0 0 1 1.734 0 1.234 1.234 0 0 1 0 1.732l-1.154 1.468zM4 8.933v6.68c0 .44.147.806.44 1.1.293.293.66.44 1.1.44h13.333c.44 0 .806-.147 1.1-.44.293-.294.44-.66.44-1.1V8.933c0-.44-.147-.806-.44-1.1-.294-.293-.66-.44-1.1-.44H5.54c-.44 0-.806.147-1.1.44-.293.294-.44.66-.44 1.1zm4.373 5.293a.88.88 0 0 1-.88-.88V11.28c0-.484.396-.88.88-.88h.547a.88.88 0 0 1 .88.88v2.067c0 .484-.396.88-.88.88h-.547zm6.933 0a.88.88 0 0 1-.88-.88V11.28a.88.88 0 0 1 .88-.88h.547a.88.88 0 0 1 .88.88v2.067a.88.88 0 0 1-.88.88h-.547z"/></svg>
            </a>
          </div>

          <!-- Info -->
          <div class="text-center space-y-1">
            <p class="text-xs text-[var(--text-muted)]">
              © {new Date().getFullYear()} · Built with 
              <a href="https://astro.build" class="text-[var(--text-secondary)] hover:text-accent transition-colors">Astro</a> & 
              <a href="https://tailwindcss.com" class="text-[var(--text-secondary)] hover:text-accent transition-colors">Tailwind</a>
            </p>
          </div>
        </div>
      </div>
    </footer>

    <!-- Back to Top -->
    <BackToTop client:load />

    <!-- Observers -->
    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) entry.target.classList.add('visible');
          });
        }, { threshold: 0.08, rootMargin: '0px 0px -60px 0px' });
        document.querySelectorAll('.scroll-animate').forEach(el => observer.observe(el));
      });
    </script>
  </body>
</html>

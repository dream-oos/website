---
import BaseLayout from '../layouts/BaseLayout.astro';
import friendsData from '../data/friends.json';
---

<BaseLayout title="友链 - My Site" description="我的朋友们和推荐的网站">
  <section class="pt-28 pb-16 px-5">
    <div class="mx-auto max-w-5xl">
      <!-- Header -->
      <div class="mb-10 scroll-animate">
        <p class="text-xs font-medium text-accent mb-1.5 tracking-wider uppercase">Friends</p>
        <h1 class="text-3xl sm:text-4xl font-bold tracking-tight mb-3" id="friends-title">友链</h1>
        <p class="text-[var(--text-secondary)]">海内存知己，天涯若比邻</p>
      </div>

      <!-- Grid -->
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
        {friendsData.map((friend, index) => (
          <a 
            href={friend.url}
            target="_blank"
            rel="noopener noreferrer"
            class:list={[
              "group glass-card-hover p-5 text-center scroll-animate",
              `scroll-animate-delay-${(index % 4) + 1}`
            ]}
            id={`friend-${index}`}
          >
            <div class="relative mx-auto w-14 h-14 sm:w-16 sm:h-16 mb-3">
              <img 
                src={friend.avatar} 
                alt={friend.name}
                class="w-full h-full rounded-full object-cover border-2 border-[var(--border-card)] group-hover:border-accent/40 transition-all duration-500 group-hover:scale-110 group-hover:shadow-[0_0_20px_rgba(59,158,255,0.2)]"
                loading="lazy"
              />
            </div>
            <h3 class="font-semibold text-sm mb-1 group-hover:text-accent transition-colors">{friend.name}</h3>
            <p class="text-xs text-[var(--text-secondary)] line-clamp-1 mb-2">{friend.description}</p>
            <span class="tag !text-[10px]">{friend.category}</span>
          </a>
        ))}
      </div>

      <!-- Apply -->
      <div class="mt-16 glass-card p-8 sm:p-10 text-center scroll-animate" id="apply-friend-link">
        <div class="text-3xl mb-4">🤝</div>
        <h2 class="text-xl font-bold mb-3">申请友链</h2>
        <p class="text-sm text-[var(--text-secondary)] mb-6 max-w-md mx-auto leading-relaxed">
          欢迎交换友链！请确保你的网站有独立域名，且内容积极向上。
        </p>
        <div class="flex items-center justify-center gap-3">
          <a href="mailto:hello@example.com" 
             class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-accent text-white text-sm font-medium hover:bg-accent-hover shadow-[0_0_20px_rgba(59,158,255,0.2)] hover:shadow-[0_0_30px_rgba(59,158,255,0.3)] transition-all"
             id="apply-email-btn">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
            发送邮件
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

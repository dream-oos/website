---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../config/site';
---
<BaseLayout title="关于" description={site.bio[0]}>
  <article class="container container--wide about-page">
    <header class="page-hero" data-reveal>
      <p class="eyebrow">关于</p>
      <h1>关于 {site.name}</h1>
    </header>

    <div class="about-card surface-shell" data-reveal>
      <div class="about-card__core surface-core prose">
        {site.bio.map((para) => <p>{para}</p>)}
        <p>我偏爱安静、留白和能被长期维护的东西：清晰的类型、克制的界面、诚实的文字，以及让人愿意多停留一秒的微交互。</p>
        <p><a class="cta-pill cta-pill--ghost" href={`mailto:${site.email}`}>联系我 <span class="cta-pill__icon" aria-hidden="true">↗</span></a></p>
      </div>
    </div>
  </article>
</BaseLayout>
<style>
  .about-page { padding-block: clamp(3rem, 8vw, 6rem); }
  .page-hero { max-width: 58rem; }
  .page-hero h1 { max-width: 9ch; }
  .about-card { max-width: 54rem; margin-top: clamp(2rem, 5vw, 3rem); }
  .about-card__core { padding: clamp(1.3rem, 4vw, 2.2rem); }
  .about-card__core.prose { padding-block: clamp(1.3rem, 4vw, 2.2rem); }
</style>

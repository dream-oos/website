---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({ params: { slug: project.id }, props: { project } }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const { title, year, description, link, tags = [] } = project.data;
---
<BaseLayout title={title} description={description}>
  <article class="container project-page">
    <header class="project-hero" data-reveal>
      <p class="eyebrow">作品 / {year}</p>
      <h1>{title}</h1>
      <p class="muted project-desc">{description}</p>
      {tags.length > 0 && <ul class="tags">{tags.map((tag) => <li>{tag}</li>)}</ul>}
      {link && (
        <a class="cta-pill" href={link} target="_blank" rel="noopener">
          访问项目
          <span class="cta-pill__icon" aria-hidden="true">↗</span>
        </a>
      )}
    </header>

    <div class="project-body surface-shell" data-reveal>
      <div class="prose surface-core">
        <Content />
      </div>
    </div>
  </article>
</BaseLayout>
<style>
  .project-page { padding-block: clamp(3rem, 8vw, 6rem); }
  .project-hero { display: grid; justify-items: start; max-width: 58rem; }
  .project-hero h1 { font-size: clamp(2.45rem, 6.5vw, 4.8rem); }
  .project-desc {
    max-width: 38rem;
    margin-top: 1.1rem;
    font-size: clamp(1.06rem, 1.6vw, 1.26rem);
    line-height: 1.75;
  }
  .tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: .45rem;
    padding: 0;
    margin-top: 1.25rem;
  }
  .tags li {
    border: 1px solid rgba(67, 47, 31, .09);
    border-radius: 999px;
    background: rgba(255, 253, 247, .56);
    color: var(--color-text-secondary);
    font-size: .7rem;
    font-weight: 720;
    line-height: 1;
    padding: .5rem .72rem;
  }
  .project-hero .cta-pill { margin-top: 1.5rem; }
  .project-body { margin-top: clamp(2rem, 5vw, 3rem); }
  .project-body .prose { padding: clamp(1.3rem, 4vw, 2.35rem); }
</style>

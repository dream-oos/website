---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import TypeWriter from '../components/TypeWriter.tsx';
import Hitokoto from '../components/Hitokoto.tsx';
import { getCollection } from 'astro:content';
import { siteConfig } from '../data/site.config';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const latestPosts = allPosts
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 6);
---
export const prerender = true;

<BaseLayout title={`${siteConfig.name} - Homepage`} description={siteConfig.description}>
  <section class="relative flex items-center justify-center min-h-[100svh] px-5" id="hero">
    <div class="text-center max-w-xl mx-auto">
      <div class="relative inline-block mb-8 scroll-animate" id="hero-avatar">
        <div class="avatar-ring w-28 h-28 sm:w-32 sm:h-32 rounded-full overflow-hidden">
          <img src={siteConfig.avatar} alt={siteConfig.name} width="128" height="128"
            class="w-full h-full rounded-full object-cover"
            onerror="this.onerror=null;this.src='/avatar.jpg'" />
        </div>
        <span class="absolute bottom-1 right-1 w-4 h-4 rounded-full bg-emerald-400 border-2 border-[var(--bg-primary)] shadow-[0_0_8px_rgba(52,211,153,0.6)]"></span>
      </div>

      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold mb-3 tracking-tight scroll-animate scroll-animate-delay-1" id="hero-name">
        <span class="text-gradient">{siteConfig.name}</span>
      </h1>

      <p class="text-sm text-[var(--text-muted)] mb-5 scroll-animate scroll-animate-delay-2">
        {siteConfig.tagline}
      </p>

      <div class="h-7 mb-6 text-base sm:text-lg text-[var(--text-secondary)] scroll-animate scroll-animate-delay-3" id="typewriter-container">
        <TypeWriter client:load texts={siteConfig.heroTexts} typingSpeed={80} deletingSpeed={40} pauseDuration={2500} />
      </div>

      <div class="mb-10 scroll-animate scroll-animate-delay-4" id="hitokoto-wrapper">
        <Hitokoto client:load />
      </div>

      <div class="flex items-center justify-center gap-3 mb-16 scroll-animate scroll-animate-delay-4" id="hero-social">
        {siteConfig.social.github && (
          <a href={siteConfig.social.github} target="_blank" rel="noopener noreferrer"
            class="w-11 h-11 rounded-xl glass-card flex items-center justify-center text-[var(--text-muted)] hover:text-accent hover:border-accent/25 hover:shadow-[0_0_20px_rgba(59,158,255,0.15)] transition-all duration-300"
            aria-label="GitHub" id="hero-github">
            <svg class="w-[18px] h-[18px]" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
          </a>
        )}
        {siteConfig.social.email && (
          <a href={siteConfig.social.email}
            class="w-11 h-11 rounded-xl glass-card flex items-center justify-center text-[var(--text-muted)] hover:text-accent hover:border-accent/25 hover:shadow-[0_0_20px_rgba(59,158,255,0.15)] transition-all duration-300"
            aria-label="Email" id="hero-email">
            <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
            </svg>
          </a>
        )}
        {siteConfig.social.bilibili && (
          <a href={siteConfig.social.bilibili} target="_blank" rel="noopener noreferrer"
            class="w-11 h-11 rounded-xl glass-card flex items-center justify-center text-[var(--text-muted)] hover:text-[#fb7299] hover:border-[#fb7299]/30 hover:shadow-[0_0_20px_rgba(251,114,153,0.2)] transition-all duration-300"
            aria-label="Bilibili" id="hero-bilibili">
            <svg class="w-[18px] h-[18px]" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.813 4.653h.854c1.51.054 2.769.578 3.773 1.574 1.004.995 1.524 2.249 1.56 3.76v7.36c-.036 1.51-.556 2.769-1.56 3.773s-2.262 1.524-3.773 1.56H5.333c-1.51-.036-2.769-.556-3.773-1.56S.036 18.858 0 17.347v-7.36c.036-1.511.556-2.765 1.56-3.76 1.004-.996 2.262-1.52 3.773-1.574h.774l-1.174-1.12a1.234 1.234 0 0 1 0-1.733 1.234 1.234 0 0 1 1.734 0L8.58 4.653h6.84l1.813-1.7a1.234 1.234 0 0 1 1.734 0 1.234 1.234 0 0 1 0 1.732l-1.154 1.468zM4 8.933v6.68c0 .44.147.806.44 1.1.293.293.66.44 1.1.44h13.333c.44 0 .806-.147 1.1-.44.293-.294.44-.66.44-1.1V8.933c0-.44-.147-.806-.44-1.1-.294-.293-.66-.44-1.1-.44H5.54c-.44 0-.806.147-1.1.44-.293.294-.44.66-.44 1.1zm4.373 5.293a.88.88 0 0 1-.88-.88V11.28c0-.484.396-.88.88-.88h.547a.88.88 0 0 1 .88.88v2.067c0 .484-.396.88-.88.88h-.547zm6.933 0a.88.88 0 0 1-.88-.88V11.28a.88.88 0 0 1 .88-.88h.547a.88.88 0 0 1 .88.88v2.067a.88.88 0 0 1-.88.88h-.547z"/>
            </svg>
          </a>
        )}
      </div>

      <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce-slow">
        <a href="#latest-posts" class="text-[var(--text-muted)] hover:text-accent transition-colors" aria-label="scroll">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5L12 21m0 0l-7.5-7.5M12 21V3"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <section class="py-24 px-5" id="latest-posts">
    <div class="mx-auto max-w-5xl">
      <div class="flex items-end justify-between mb-10 scroll-animate">
        <div>
          <p class="text-xs font-medium text-accent mb-1.5 tracking-wider uppercase">Blog</p>
          <h2 class="text-2xl sm:text-3xl font-bold tracking-tight">Latest Posts</h2>
        </div>
        <a href="/blog" class="group text-sm text-[var(--text-secondary)] hover:text-accent transition-colors flex items-center gap-1.5" id="view-all-posts">
          View All
          <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/>
          </svg>
        </a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {latestPosts.map((post, index) => (
          <a href={`/blog/${post.id}`}
            class:list={["group block glass-card-hover p-5 scroll-animate", `scroll-animate-delay-${Math.min(index + 1, 4)}`]}
            id={`latest-post-${index}`}>
            <div class="flex flex-col h-full min-h-[160px]">
              <div class="flex flex-wrap gap-1.5 mb-3">
                {post.data.tags.slice(0, 2).map(tag => (<span class="tag">{tag}</span>))}
              </div>
              <h3 class="text-[15px] font-semibold mb-2 group-hover:text-accent transition-colors leading-snug line-clamp-2">{post.data.title}</h3>
              <p class="text-sm text-[var(--text-secondary)] mb-auto line-clamp-2 leading-relaxed">{post.data.description}</p>
              <time datetime={post.data.pubDate.toISOString()} class="text-xs text-[var(--text-muted)] mt-4 block">
                {post.data.pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'short', day: 'numeric' })}
              </time>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
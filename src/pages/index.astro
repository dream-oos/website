---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import TypeWriter from '../components/TypeWriter.tsx';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const latestPosts = allPosts
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 6);

const heroTexts = [
  "一个热爱编程的开发者 🚀",
  "开源爱好者 & 技术写作者 ✍️",
  "终身学习者，不断探索 🌟",
];
---

<BaseLayout title="My Site - 个人主页" description="个人主页 - 分享技术与生活">
  <!-- Hero -->
  <section class="relative flex items-center justify-center min-h-[100svh] px-5" id="hero">
    <div class="text-center max-w-xl mx-auto">
      <!-- Avatar -->
      <div class="relative inline-block mb-8 scroll-animate">
        <div class="avatar-ring w-28 h-28 sm:w-32 sm:h-32 rounded-full overflow-hidden">
          <div class="w-full h-full bg-[var(--bg-secondary)] flex items-center justify-center text-5xl sm:text-6xl rounded-full border-2 border-[var(--bg-tertiary)]">
            👨‍💻
          </div>
        </div>
      </div>

      <!-- Name -->
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold mb-3 tracking-tight scroll-animate scroll-animate-delay-1" id="hero-name">
        <span class="text-gradient">Your Name</span>
      </h1>

      <!-- Subtitle -->
      <p class="text-sm text-[var(--text-muted)] mb-5 scroll-animate scroll-animate-delay-2">
        Full-Stack Developer · Open Source Enthusiast
      </p>

      <!-- Typewriter -->
      <div class="h-7 mb-10 text-base sm:text-lg text-[var(--text-secondary)] scroll-animate scroll-animate-delay-3" id="typewriter-container">
        <TypeWriter client:load texts={heroTexts} typingSpeed={80} deletingSpeed={40} pauseDuration={2500} />
      </div>

      <!-- Social Links -->
      <div class="flex items-center justify-center gap-3 mb-16 scroll-animate scroll-animate-delay-4" id="hero-social">
        <a href="https://github.com" target="_blank" rel="noopener noreferrer" 
           class="w-11 h-11 rounded-xl glass-card flex items-center justify-center text-[var(--text-muted)] hover:text-accent hover:border-accent/25 hover:shadow-[0_0_20px_rgba(59,158,255,0.15)] transition-all duration-300"
           aria-label="GitHub" id="hero-github">
          <svg class="w-[18px] h-[18px]" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        </a>
        <a href="mailto:hello@example.com" 
           class="w-11 h-11 rounded-xl glass-card flex items-center justify-center text-[var(--text-muted)] hover:text-accent hover:border-accent/25 hover:shadow-[0_0_20px_rgba(59,158,255,0.15)] transition-all duration-300"
           aria-label="Email" id="hero-email">
          <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
        </a>
        <a href="https://twitter.com" target="_blank" rel="noopener noreferrer"
           class="w-11 h-11 rounded-xl glass-card flex items-center justify-center text-[var(--text-muted)] hover:text-accent hover:border-accent/25 hover:shadow-[0_0_20px_rgba(59,158,255,0.15)] transition-all duration-300"
           aria-label="Twitter" id="hero-twitter">
          <svg class="w-[18px] h-[18px]" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
      </div>

      <!-- Scroll indicator -->
      <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce-slow">
        <a href="#latest-posts" class="text-[var(--text-muted)] hover:text-accent transition-colors" aria-label="向下滚动">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5L12 21m0 0l-7.5-7.5M12 21V3"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Latest Posts -->
  <section class="py-24 px-5" id="latest-posts">
    <div class="mx-auto max-w-5xl">
      <!-- Section header -->
      <div class="flex items-end justify-between mb-10 scroll-animate">
        <div>
          <p class="text-xs font-medium text-accent mb-1.5 tracking-wider uppercase">Blog</p>
          <h2 class="text-2xl sm:text-3xl font-bold tracking-tight">最新文章</h2>
        </div>
        <a href="/blog" class="group text-sm text-[var(--text-secondary)] hover:text-accent transition-colors flex items-center gap-1.5" id="view-all-posts">
          查看全部
          <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/>
          </svg>
        </a>
      </div>

      <!-- Posts grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {latestPosts.map((post, index) => (
          <a href={`/blog/${post.id}`}
             class:list={[
               "group block glass-card-hover p-5 scroll-animate",
               `scroll-animate-delay-${Math.min(index + 1, 4)}`
             ]}
             id={`latest-post-${index}`}>
            <div class="flex flex-col h-full min-h-[160px]">
              <!-- Tags -->
              <div class="flex flex-wrap gap-1.5 mb-3">
                {post.data.tags.slice(0, 2).map(tag => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
              
              <!-- Title -->
              <h3 class="text-[15px] font-semibold mb-2 group-hover:text-accent transition-colors leading-snug line-clamp-2">
                {post.data.title}
              </h3>
              
              <!-- Description -->
              <p class="text-sm text-[var(--text-secondary)] mb-auto line-clamp-2 leading-relaxed">
                {post.data.description}
              </p>
              
              <!-- Date -->
              <time 
                datetime={post.data.pubDate.toISOString()} 
                class="text-xs text-[var(--text-muted)] mt-4 block"
              >
                {post.data.pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'short', day: 'numeric' })}
              </time>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import projectsData from '../data/projects.json';

const iconMap: Record<string, string> = {
  Globe: '🌐',
  ListTodo: '📋',
  CloudSun: '⛅',
  Terminal: '⌨️',
};
---

<BaseLayout title="项目 - My Site" description="我的开源项目和作品展示">
  <section class="pt-28 pb-16 px-5">
    <div class="mx-auto max-w-5xl">
      <!-- Header -->
      <div class="mb-10 scroll-animate">
        <p class="text-xs font-medium text-accent mb-1.5 tracking-wider uppercase">Projects</p>
        <h1 class="text-3xl sm:text-4xl font-bold tracking-tight mb-3" id="projects-title">项目</h1>
        <p class="text-[var(--text-secondary)]">我的开源项目和个人作品</p>
      </div>

      <!-- Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {projectsData.map((project, index) => (
          <div 
            class:list={[
              "group glass-card-hover p-6 scroll-animate",
              `scroll-animate-delay-${Math.min(index + 1, 4)}`
            ]}
            id={`project-${index}`}
          >
            <!-- Icon + Title -->
            <div class="flex items-start gap-4 mb-4">
              <div class="w-11 h-11 rounded-xl bg-[var(--bg-tertiary)] border border-[var(--border-card)] flex items-center justify-center text-xl shrink-0">
                {iconMap[project.icon] || '📦'}
              </div>
              <div class="flex-1 min-w-0">
                <h3 class="text-base font-semibold group-hover:text-accent transition-colors leading-snug">
                  {project.title}
                </h3>
                <p class="text-sm text-[var(--text-secondary)] mt-1 leading-relaxed line-clamp-2">
                  {project.description}
                </p>
              </div>
            </div>

            <!-- Tags via shadcn Badge (outline variant) -->
            <div class="flex flex-wrap gap-1.5 mb-4" id={`project-tags-${index}`}>
              {project.tags.map(tag => (
                <span data-slot="badge" data-variant="outline" class="group/badge inline-flex h-5 w-fit shrink-0 items-center justify-center gap-1 overflow-hidden rounded-full border px-2 py-0.5 text-xs font-medium whitespace-nowrap border-[var(--border-card)] text-[var(--text-secondary)] bg-[var(--bg-tertiary)]">
                  {tag}
                </span>
              ))}
            </div>

            <!-- Links via shadcn Button (ghost/outline variants) -->
            <div class="flex items-center gap-2 pt-3 border-t border-[var(--border-card)]">
              <a 
                href={project.github} 
                target="_blank" 
                rel="noopener noreferrer"
                data-slot="button" data-variant="ghost" data-size="sm"
                class="group/button inline-flex shrink-0 items-center justify-center rounded-lg border border-transparent bg-clip-padding text-xs font-medium whitespace-nowrap transition-all h-7 gap-1 px-2.5 hover:bg-[var(--bg-tertiary)] hover:text-accent text-[var(--text-muted)]"
              >
                <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                源码
              </a>
              {project.demo && (
                <a 
                  href={project.demo} 
                  target="_blank" 
                  rel="noopener noreferrer"
                  data-slot="button" data-variant="outline" data-size="sm"
                  class="group/button inline-flex shrink-0 items-center justify-center rounded-lg border bg-clip-padding text-xs font-medium whitespace-nowrap transition-all h-7 gap-1 px-2.5 border-[var(--border-card)] bg-transparent hover:bg-[var(--bg-tertiary)] hover:text-accent text-[var(--text-muted)]"
                >
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/></svg>
                  演示
                </a>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

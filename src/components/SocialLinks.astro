---
import type { SocialLink } from '../config/site';
interface Props { links: SocialLink[]; }
const { links } = Astro.props;
---
<ul class="socials">
  {links.map((l) => (
    <li>
      <a href={l.href} rel="me">
        <span>{l.label}</span>
        <span class="socials__dot" aria-hidden="true">↗</span>
      </a>
    </li>
  ))}
</ul>
<style>
  .socials {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: .5rem;
    padding: 0;
  }

  .socials a {
    display: inline-flex;
    align-items: center;
    gap: .45rem;
    min-height: 2.35rem;
    border: 1px solid rgb(var(--ink-rgb) / .1);
    border-radius: 999px;
    background: rgb(var(--surface-rgb) / .58);
    color: var(--color-text-secondary);
    padding: .26rem .32rem .26rem .78rem;
    font-size: .78rem;
    font-weight: 720;
    line-height: 1;
    box-shadow: inset 0 1px 1px rgb(var(--highlight-rgb) / .82);
    transition: transform .62s var(--motion), color .62s var(--motion), background-color .62s var(--motion), border-color .62s var(--motion);
  }

  .socials a:hover {
    border-color: rgb(var(--accent-hover-rgb) / .18);
    background: rgb(var(--surface-rgb) / .86);
    color: var(--color-accent-hover);
    transform: translateY(-1px);
  }

  .socials a:active { transform: scale(.98); }

  .socials__dot {
    display: inline-grid;
    place-items: center;
    width: 1.65rem;
    height: 1.65rem;
    border-radius: 999px;
    background: rgb(var(--chip-rgb) / .055);
    color: var(--color-ink);
    font-size: .7rem;
    transition: transform .62s var(--motion), background-color .62s var(--motion);
  }

  .socials a:hover .socials__dot {
    background: rgb(var(--accent-rgb) / .12);
    transform: translate(.12rem, -.04rem) scale(1.05);
  }
</style>

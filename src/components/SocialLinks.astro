---
import type { SocialLink } from '../config/site';
interface Props { links: SocialLink[]; }
const { links } = Astro.props;
---
<ul class="socials">
  {links.map((l) => (
    <li><a href={l.href} rel="me">{l.label}</a></li>
  ))}
</ul>
<style>
  .socials { list-style: none; display: flex; gap: .5rem; padding: 0; flex-wrap: wrap; }
  .socials a {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    border-radius: 999px;
    padding-inline: .15rem;
    font-size: .86rem;
    line-height: 1;
  }
</style>

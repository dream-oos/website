---
---

<div class="floating-toolbar" id="floating-toolbar">
  <div class="toc-popup" id="toc-popup">
    <div class="toc-popup__header">
      <span class="toc-popup__title">目录</span>
      <button class="toc-popup__close" id="toc-close" aria-label="关闭目录">
        <i class="fa-solid fa-xmark"></i>
      </button>
    </div>
    <nav class="toc-nav" id="toc-nav"></nav>
  </div>
  <button class="ft-btn" id="ft-toc" title="目录" aria-label="目录">
    <i class="fa-solid fa-list-ul"></i>
  </button>
  <button class="ft-btn ft-btn--hidden" id="ft-comments" title="评论" aria-label="跳转到评论">
    <i class="fa-solid fa-comments"></i>
  </button>
  <button class="ft-btn ft-btn--hidden" id="ft-top" title="回到顶部" aria-label="回到顶部">
    <i class="fa-solid fa-arrow-up"></i>
  </button>
</div>

<script>
  const prose = document.querySelector('.prose');
  const headings = prose?.querySelectorAll<HTMLHeadingElement>('h2, h3');
  const tocNav = document.getElementById('toc-nav');
  const tocPopup = document.getElementById('toc-popup');
  const tocBtn = document.getElementById('ft-toc');
  const tocClose = document.getElementById('toc-close');
  const commentsBtn = document.getElementById('ft-comments');
  const topBtn = document.getElementById('ft-top');
  const walineEl = document.getElementById('waline-container');

  if (!prose || !headings || headings.length === 0) {
    tocBtn?.classList.add('ft-btn--hidden');
  }

  function slugify(text: string): string {
    return text
      .trim()
      .toLowerCase()
      .replace(/[^\w\u4e00-\u9fff\s-]/g, '')
      .replace(/\s+/g, '-')
      .replace(/-+/g, '-')
      .replace(/^-|-$/g, '');
  }

  if (headings && tocNav) {
    const list = document.createElement('ul');
    list.className = 'toc-list';

    headings.forEach((h) => {
      const id = h.id || slugify(h.textContent ?? '');
      if (!h.id) h.id = id;

      const li = document.createElement('li');
      li.className = h.tagName === 'H3' ? 'toc-item toc-item--sub' : 'toc-item';

      const a = document.createElement('a');
      a.href = `#${id}`;
      a.textContent = h.textContent;
      a.className = 'toc-link';
      a.dataset.target = id;

      a.addEventListener('click', (e) => {
        e.preventDefault();
        closePopup();
        const target = document.getElementById(id);
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });

      li.append(a);
      list.append(li);
    });

    tocNav.append(list);
  }

  const tocLinks = document.querySelectorAll<HTMLAnchorElement>('.toc-link');

  if (headings && headings.length > 0) {
    const headingObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const id = entry.target.id;
            tocLinks.forEach((link) => {
              link.classList.remove('toc-link--active');
            });
            const active = tocNav?.querySelector<HTMLAnchorElement>(`[data-target="${id}"]`);
            if (active) {
              active.classList.add('toc-link--active');
            }
          }
        });
      },
      { rootMargin: '-10% 0px -70% 0px', threshold: 0 },
    );

    headings.forEach((h) => headingObserver.observe(h));
  }

  function closePopup() {
    tocPopup?.classList.remove('toc-popup--open');
  }

  function togglePopup() {
    tocPopup?.classList.toggle('toc-popup--open');
  }

  tocBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    togglePopup();
  });

  tocClose?.addEventListener('click', (e) => {
    e.stopPropagation();
    closePopup();
  });

  document.addEventListener('click', (e) => {
    if (tocPopup?.classList.contains('toc-popup--open')) {
      const target = e.target as Node;
      if (!tocPopup.contains(target) && target !== tocBtn && !tocBtn?.contains(target)) {
        closePopup();
      }
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && tocPopup?.classList.contains('toc-popup--open')) {
      closePopup();
    }
  });

  function onScroll() {
    const scrolled = window.scrollY > window.innerHeight * 0.6;
    const method = scrolled ? 'remove' : 'add';
    commentsBtn?.classList[method]('ft-btn--hidden');
    topBtn?.classList[method]('ft-btn--hidden');
  }

  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  commentsBtn?.addEventListener('click', () => {
    if (walineEl) {
      walineEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  });

  topBtn?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>
